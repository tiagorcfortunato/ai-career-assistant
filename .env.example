GROQ_API_KEY=your_key_here
LLM_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
CHROMA_PATH=./chroma_db
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Candidate pool size pulled from hybrid RRF search before reranking.
# Wider is better for rerank quality; 20 is a good default.
RETRIEVAL_K=20

# Cross-encoder reranker (see app/services/graph.py :: rerank_node).
# Scores each (query, chunk) jointly and returns a sigmoid-normalised
# relevance in [0, 1] — unlike RRF which only encodes rank position.
#
# Default is the multilingual Jina reranker because production traffic
# mixes English + German. For an English-only corpus the lighter MS MARCO
# MiniLM (Xenova/ms-marco-MiniLM-L-6-v2) is a fine swap.
RAG_RERANK_MODEL=jinaai/jina-reranker-v2-base-multilingual
RAG_RERANK_TOP_K=5
RAG_RERANK_MIN_SCORE=0.3
