GROQ_API_KEY=your_key_here
LLM_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
CHROMA_PATH=./chroma_db
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_K=4

# Low-confidence retrieval thresholds (see app/services/graph.py :: evaluate_retrieval_node).
# Tune based on logged scores — defaults assume a [0,1] similarity range; the
# current RRF fused score is much smaller (≲0.033), so you will likely want
# something like RAG_THRESHOLD_HI=0.02, RAG_THRESHOLD_MID=0.015 in practice.
RAG_THRESHOLD_HI=0.3
RAG_THRESHOLD_MID=0.5
RAG_MIN_CHUNKS=2
